ent-DisposalPipeBase = { "" }
    .desc = { "" }
ent-DisposalHolder = держатель утилизационного блока
    .desc = { "" }
ent-DisposalPipeBroken = поврежденная утилизационная труба
    .desc = БПТ (большая поврежденная труба).
ent-DisposalPipe = участок утилизационной трубы
    .desc = Огромный сегмент трубы, используемый для строительства систем утилизации.
ent-DisposalTagger = маркировщик утилизационной трубы
    .desc = Труба, которая помечает объекты для маршрутизации.
ent-DisposalSignaller = сигнализатор утилизации
    .desc = Труба, которая испускает сигнал, когда предмет проходит через неё.
ent-DisposalTrunk = ствол утилизационной трубы
    .desc = Ствол трубы, используемый в качестве точки входа для систем утилизации.
ent-DisposalRouter = маршрутизатор утилизационной трубы
    .desc = Утилизационная труба, способная фильтровать предметы на основе метки. Предметы, поступающие с выходов, не фильтруются и вместо этого отправляются на вход.
ent-DisposalRouterFlipped = { ent-DisposalRouter }
    .desc = { ent-DisposalRouter.desc }
    .suffix = перевернутый
ent-DisposalJunction = развязка утилизационной трубы
    .desc = Объединяет 2 трубы в одну. Предметы, поступающие с выхода, движутся прямо.
ent-DisposalJunctionFlipped = { ent-DisposalJunction }
    .desc = Объединяет 2 трубы в одну. Предметы, поступающие с выхода, движутся прямо.
    .suffix = перевернутый
ent-DisposalYJunction = Т-образная утилизационная труба
    .desc = Объединяет 2 трубы сбоку в одну. Предметы, поступающие с выхода, покидают её через правый вход.
ent-DisposalXJunction = утилизационный соединитель 3-1
    .desc = Объединяет 3 трубы в 1. Предметы, поступающие с выхода, движутся прямо.
ent-DisposalBend = изгиб утилизационной трубы
    .desc = Труба, изогнутая под углом 90 градусов.
ent-DisposalSignalRouter = сигнальный маршрутизатор мусора
    .desc = Управляемый сигналом трёхходовой маршрутизатор.
ent-DisposalSignalRouterFlipped = { ent-DisposalSignalRouter }
    .desc = { ent-DisposalSignalRouter.desc }
    .suffix = перевернутый
